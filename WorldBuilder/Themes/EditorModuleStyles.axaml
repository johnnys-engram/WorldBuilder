<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Button.toolbar-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
    </Style>
    <Style Selector="Button.toolbar-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#33000000" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
    </Style>

    <Style Selector="TextBlock.section-header">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="Margin" Value="0,12,0,6" />
    </Style>

    <Style Selector="TextBlock.field-label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="120" />
    </Style>

    <Style Selector="TextBlock.panel-caption">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
    </Style>

    <Style Selector="TextBlock.editor-hint">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
    </Style>

    <Style Selector="TextBlock.editor-list-meta">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
    </Style>

    <Style Selector="TextBlock.editor-empty">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText2}" />
    </Style>

    <Style Selector="TextBlock.help-icon">
        <Setter Property="Text" Value="?" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
        <Setter Property="Background" Value="{DynamicResource SemiColorFill2}" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="4,0,0,0" />
    </Style>

    <Style Selector="TextBox.field-input">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="{DynamicResource SemiColorFill1}" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="CaretBrush" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="SelectionBrush" Value="{DynamicResource SemiColorPrimary}" />
        <Setter Property="SelectionForegroundBrush" Value="White" />
    </Style>

    <Style Selector="TextBox.search-box">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="{DynamicResource SemiColorFill1}" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="CaretBrush" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="SelectionBrush" Value="{DynamicResource SemiColorPrimary}" />
        <Setter Property="SelectionForegroundBrush" Value="White" />
    </Style>

    <Style Selector="TextBox.layout-hex">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
        <Setter Property="Background" Value="{DynamicResource SemiColorFill1}" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="CaretBrush" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>

    <Style Selector="ComboBox.field-input">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Background" Value="{DynamicResource SemiColorFill1}" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="PlaceholderForeground" Value="{DynamicResource SemiColorText2}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="ComboBox.field-input /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="Background" Value="{DynamicResource SemiColorFill1}" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SemiColorFill2}" />
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SemiColorPrimaryLight}" />
    </Style>

    <Style Selector="Button.sm-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
    </Style>
    <Style Selector="Button.sm-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#33000000" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
    </Style>

    <Style Selector="Button.small-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
    </Style>
    <Style Selector="Button.small-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#33000000" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
    </Style>

    <Style Selector="Button.field-dropdown">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="8,4,28,4" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="MaxWidth" Value="300" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="Background" Value="{DynamicResource SemiColorFill1}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.field-dropdown TextBlock.dropdown-value">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
    </Style>
    <Style Selector="Button.field-dropdown TextBlock.dropdown-arrow">
        <Setter Property="Text" Value="&#x25BC;" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText2}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="6,0,0,0" />
    </Style>

    <Style Selector="ListBox.editor-listbox">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="Background" Value="{DynamicResource SemiColorFill0}" />
    </Style>
    <Style Selector="ListBox.editor-listbox ListBoxItem">
        <Setter Property="Padding" Value="2,4" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
    </Style>
    <Style Selector="ListBox.editor-listbox ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SemiColorPrimary}" />
    </Style>
    <Style Selector="ListBox.editor-listbox ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SemiColorPrimary}" />
    </Style>
    <Style Selector="ListBox.editor-listbox ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SemiColorFill2}" />
    </Style>
    <Style Selector="ListBox.editor-listbox ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ListBox.editor-listbox ListBoxItem:selected:pointerover TextBlock">
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ListBox.editor-listbox ListBoxItem:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
    </Style>
    <Style Selector="Flyout CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
    </Style>

    <Style Selector="TabControl.editor-tabs TabItem">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TabControl.editor-tabs TabItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{DynamicResource SemiColorPrimaryLight}" />
    </Style>
    <Style Selector="TabControl.editor-tabs TabItem:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
    </Style>
    <Style Selector="TabControl.editor-tabs TabStripItem">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
    </Style>
    <Style Selector="TabControl.editor-tabs TabStripItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.prop-label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
        <Setter Property="Width" Value="120" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.prop-value">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.editor-panel">
        <Setter Property="Background" Value="{DynamicResource SemiColorFill1}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BoxShadow" Value="0 1 4 0 #18000000" />
    </Style>

    <Style Selector="Border.module-toolbar">
        <Setter Property="Background" Value="{DynamicResource SemiColorFill0}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="BoxShadow" Value="0 2 8 0 #12000000" />
    </Style>

    <Style Selector="Border.module-chrome-split">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{DynamicResource SemiColorBorder}" />
        <Setter Property="Margin" Value="4,2" />
    </Style>
</Styles>
