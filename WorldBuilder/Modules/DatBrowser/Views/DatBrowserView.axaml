<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:WorldBuilder.Modules.DatBrowser.ViewModels"
             xmlns:v="using:WorldBuilder.Modules.DatBrowser.Views"
             xmlns:views="using:WorldBuilder.Views"
             xmlns:conv="using:WorldBuilder.Converters"
             xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mainComponents="using:WorldBuilder.Views.Components"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="WorldBuilder.Modules.DatBrowser.Views.DatBrowserView"
             x:Name="DatBrowserRoot"
             x:DataType="vm:DatBrowserViewModel">
    <UserControl.Resources>
        <StreamGeometry x:Key="WarningIcon">M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z</StreamGeometry>
        
        <!-- Chevron Path Resources -->
        <DataTemplate x:Key="CollapsedChevronTemplate">
            <Path Data="{StaticResource TreeDataGridItemCollapsedChevronPathData}"
                  Fill="{DynamicResource SemiColorTertiary}"
                  Stretch="Uniform"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
        </DataTemplate>
        
        <DataTemplate x:Key="ExpandedChevronTemplate">
            <Path Data="{StaticResource TreeDataGridItemExpandedChevronPathData}"
                  Fill="{DynamicResource SemiColorTertiary}"
                  Stretch="Uniform"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
        </DataTemplate>
    </UserControl.Resources>
    <UserControl.DataTemplates>
        <DataTemplate DataType="vm:SetupBrowserViewModel">
            <v:SetupBrowserView/>
        </DataTemplate>
        <DataTemplate DataType="vm:ParticleEmitterBrowserViewModel">
            <v:ParticleEmitterBrowserView/>
        </DataTemplate>
        <DataTemplate DataType="vm:GfxObjBrowserViewModel">
            <v:GfxObjBrowserView/>
        </DataTemplate>
        <DataTemplate DataType="vm:SurfaceTextureBrowserViewModel">
            <v:SurfaceTextureBrowserView/>
        </DataTemplate>
        <DataTemplate DataType="vm:RenderSurfaceBrowserViewModel">
            <v:RenderSurfaceBrowserView/>
        </DataTemplate>
        <DataTemplate DataType="vm:SurfaceBrowserViewModel">
            <v:SurfaceBrowserView/>
        </DataTemplate>
        <DataTemplate DataType="vm:EnvCellBrowserViewModel">
            <v:EnvCellBrowserView/>
        </DataTemplate>
        <DataTemplate DataType="vm:SurfaceTextureOverviewViewModel">
            <v:SurfaceTextureOverviewView/>
        </DataTemplate>
        <DataTemplate DataType="vm:EnvCellOverviewViewModel">
            <v:EnvCellOverviewView/>
        </DataTemplate>
        <DataTemplate DataType="vm:ParticleEmitterOverviewViewModel">
            <v:ParticleEmitterOverviewView/>
        </DataTemplate>
    </UserControl.DataTemplates>

    <UserControl.Styles>
        <StyleInclude Source="avares://WorldBuilder/Themes/EditorModuleStyles.axaml" />
        <!-- Shared overview styles, used by SurfaceTextureOverviewView and EnvCellOverviewView -->
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SemiColorPrimaryLight}"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border#ItemBorder">
            <Setter Property="BorderBrush" Value="{DynamicResource SemiColorPrimary}"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource SemiColorPrimaryLight}"/>
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="Padding" Value="0,1"/>
        </Style>
        <Style Selector="TreeView TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <Border DockPanel.Dock="Top" Classes="module-toolbar">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding DatTypes}"
                              SelectedItem="{Binding SelectedType}"
                              HorizontalAlignment="Stretch"
                              MinWidth="200"
                              MaxWidth="420"
                              Classes="field-input" />
                    <Button Content="Browse"
                            Command="{Binding BrowseCommand}"
                            IsVisible="{Binding CanBrowse}"
                            VerticalAlignment="Center"
                            Classes="toolbar-btn" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="12,0,0,0" VerticalAlignment="Center" IsVisible="{Binding IsSearchVisible}">
                    <mainComponents:KeywordsSearchControl DataContext="{Binding}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid ColumnDefinitions="*, Auto, 400" Background="{DynamicResource SemiColorBackground0}">
        <ContentControl Grid.Column="0" Content="{Binding CurrentBrowser}" />

        <GridSplitter Grid.Column="1" Width="1" Background="{DynamicResource SemiColorBorder}" HorizontalAlignment="Stretch"
                      IsVisible="{Binding SelectedObject, Converter={x:Static conv:NumericConverters.IsNotZero}}" />

        <TabControl Grid.Column="2" SelectedIndex="{Binding SelectedPropertiesTabIndex}"
                    IsVisible="{Binding SelectedObject, Converter={x:Static conv:NumericConverters.IsNotZero}}" HorizontalAlignment="Stretch"
                    Classes="editor-tabs">
            <TabItem Header="Overview" IsVisible="{Binding ObjectOverview, Converter={x:Static ObjectConverters.IsNotNull}}">
                <ContentControl Content="{Binding ObjectOverview}" />
            </TabItem>
            <TabItem Header="Props">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding ReflectionNodes.VisibleRows}" 
                             SelectedItem="{Binding ReflectionNodes.SelectedItem}"
                             Padding="0,5.5,10,0"
                             DoubleTapped="OnDoubleTapped"
                             KeyDown="OnKeyDown">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" MinHeight="27">
                                    <Grid ColumnDefinitions="Auto,21,*">
                                        <Border Width="{Binding Indent}"/>
                                        <Button Grid.Column="1"
                                                Command="{Binding $parent[TabControl].DataContext.ToggleExpandedCommand}"
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding HasChildren}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="6"
                                                MinHeight="0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Width="22" Height="22">
                                            <Grid>
                                                <ContentControl Content="{Binding}"
                                                               ContentTemplate="{StaticResource CollapsedChevronTemplate}"
                                                               IsVisible="{Binding !IsExpanded}" />
                                                <ContentControl Content="{Binding}"
                                                               ContentTemplate="{StaticResource ExpandedChevronTemplate}"
                                                               IsVisible="{Binding IsExpanded}" />
                                            </Grid>
                                            <Button.Styles>
                                                <Style Selector=":pointerover /template/ ContentPresenter">
                                                    <Setter Property="Background" Value="Transparent" />
                                                </Style>
                                                <Style Selector="Button:pointerover Path">
                                                    <Setter Property="Fill" Value="{DynamicResource SemiColorText0}" />
                                                </Style>
                                            </Button.Styles>
                                        </Button>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Background="Transparent">
                                            <StackPanel.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Copy" Command="{Binding Node.CopyCommand}"/>
                                                    <MenuItem Header="Open in New Window" Command="{Binding Node.OpenInNewWindowCommand}" IsVisible="{Binding Node.IsQualifiedDataId}"/>
                                                </ContextMenu>
                                            </StackPanel.ContextMenu>
                                            <TextBlock Text="{Binding Node.Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Text=": " VerticalAlignment="Center"/>

                                            <v:DataIdView IsVisible="{Binding IsQualifiedDataId}" VerticalAlignment="Center" DataContext="{Binding Node}"/>

                                            <StackPanel Orientation="Horizontal" IsVisible="{Binding !Node.IsQualifiedDataId}" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Node.Value}" Foreground="{DynamicResource SemiColorText2}" IsVisible="{Binding Node.Value, Converter={x:Static ObjectConverters.IsNotNull}}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Node.TypeName, StringFormat=' ({0})'}" Foreground="{DynamicResource SemiColorText3}" FontSize="10" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Keywords" IsVisible="{Binding ShowKeywords}">
                <ScrollViewer>
                    <StackPanel Margin="10" Spacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Names" Classes="editor-hint" FontWeight="SemiBold" Margin="5,0"/>
                            <TextBox Text="{Binding CurrentKeywordsNames}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     Classes="field-input"
                                     Padding="10" />
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock Text="Tags" Classes="editor-hint" FontWeight="SemiBold" Margin="5,0"/>
                            <TextBox Text="{Binding CurrentKeywordsTags}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     Classes="field-input"
                                     Padding="10" />
                        </StackPanel>
                        
                        <StackPanel Spacing="2">
                            <TextBlock Text="Descriptions" Classes="editor-hint" FontWeight="SemiBold" Margin="5,0"/>
                            <TextBox Text="{Binding CurrentKeywordsDescriptions}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     Classes="field-input"
                                     Padding="10" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        </Grid>
    </DockPanel>
</UserControl>
