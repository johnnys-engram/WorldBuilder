<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:WorldBuilder.Views"
             xmlns:mainComponents="clr-namespace:WorldBuilder.Views.Components"
             xmlns:vm="clr-namespace:WorldBuilder.Modules.Landscape"
             xmlns:components="clr-namespace:WorldBuilder.Modules.Landscape.Views.Components"
             xmlns:tools="clr-namespace:WorldBuilder.Shared.Modules.Landscape.Tools;assembly=WorldBuilder.Shared"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="WorldBuilder.Modules.Landscape.LandscapeView"
             x:DataType="vm:LandscapeViewModel">

  <Grid x:Name="RootLayoutGrid" ColumnDefinitions="Auto, *, Auto, Auto">
    <!-- Left Sidebar: Tools (Narrow) -->
    <components:ToolPanel Grid.Column="0" IsVisible="{Binding !IsReadOnly}" />

    <!-- Center Content -->
    <Grid x:Name="CenterGrid" Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="{Binding BottomPanelHeight, Mode=TwoWay}" />
      </Grid.RowDefinitions>
      <!-- Top Ribbon: Tool Settings -->
      <components:ToolSettingsPanel Grid.Row="0" IsVisible="{Binding !IsReadOnly}" />
      
      <!-- Viewport -->
      <Panel Grid.Row="1" DragDrop.AllowDrop="True" DragDrop.DragOver="OnViewportDragOver" DragDrop.Drop="OnViewportDrop">
        <views:RenderView x:Name="RenderView" 
                          LandscapeDocument="{Binding ActiveDocument}" 
                          Dats="{Binding Dats}"
                          BrushPosition="{Binding BrushPosition}"
                          BrushRadius="{Binding BrushRadius}"
                          BrushShape="{Binding BrushShape}"
                          ShowBrush="{Binding ShowBrush}"
                          EditorState="{Binding EditorState}"
                          Is3DCamera="{Binding Is3DCameraEnabled}" />

        <!-- Overlay Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Spacing="4">
          <StackPanel.Styles>
            <Style Selector="Button, ToggleButton">
              <Setter Property="Focusable" Value="False" />
              <Setter Property="Padding" Value="4" />
              <Setter Property="Width" Value="32" />
              <Setter Property="Height" Value="32" />
              <Setter Property="HorizontalContentAlignment" Value="Center" />
              <Setter Property="VerticalContentAlignment" Value="Center" />
              <Setter Property="Background" Value="{DynamicResource SemiColorFill0}" />
              <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
              <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
              <Setter Property="Background" Value="{DynamicResource SemiColorPrimary}" />
              <Setter Property="Opacity" Value="0.8" />
              <Setter Property="BorderBrush" Value="{DynamicResource SemiColorPrimary}" />
            </Style>
            <Style Selector="ToggleButton:checked">
              <Setter Property="Foreground" Value="White" />
            </Style>
            <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
              <Setter Property="Background" Value="{DynamicResource SemiColorFill1}" />
            </Style>
            <Style Selector="ToggleButton:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
              <Setter Property="Background" Value="{DynamicResource SemiColorPrimary}" />
              <Setter Property="Opacity" Value="1.0" />
            </Style>
          </StackPanel.Styles>
          <ToggleButton IsChecked="{Binding Is3DCameraEnabled}" ToolTip.Tip="Toggle Camera">
            <icons:MaterialIcon Kind="Camera" />
          </ToggleButton>
          <ToggleButton IsChecked="{Binding EditorState.ShowScenery}" ToolTip.Tip="Toggle Scenery">
            <icons:MaterialIcon Kind="Tree" />
          </ToggleButton>
          <ToggleButton IsChecked="{Binding EditorState.ShowBuildings}" ToolTip.Tip="Toggle Buildings">
            <icons:MaterialIcon Kind="Home" />
          </ToggleButton>
          <ToggleButton IsChecked="{Binding EditorState.ShowEnvCells}" ToolTip.Tip="Toggle EnvCells">
            <icons:MaterialIcon Kind="OfficeBuilding" />
          </ToggleButton>
          <ToggleButton IsChecked="{Binding EditorState.ShowStaticObjects}" ToolTip.Tip="Toggle Static Objects">
            <icons:MaterialIcon Kind="Cube" />
          </ToggleButton>
          <ToggleButton IsChecked="{Binding EditorState.ShowParticles}" ToolTip.Tip="Toggle Particles">
            <icons:MaterialIcon Kind="Sparkles" />
          </ToggleButton>
          <ToggleButton IsChecked="{Binding EditorState.ShowGrid}" ToolTip.Tip="Toggle Grid">
            <icons:MaterialIcon Kind="Grid" />
          </ToggleButton>
          <ToggleButton IsChecked="{Binding EditorState.ShowUnwalkableSlopes}" ToolTip.Tip="Toggle Unwalkable Slopes">
            <icons:MaterialIcon Kind="Terrain" />
          </ToggleButton>
          <ToggleButton IsChecked="{Binding EditorState.EnableCameraCollision}" ToolTip.Tip="Toggle Camera Collision">
            <icons:MaterialIcon Kind="Wall" />
          </ToggleButton>
          <Button Command="{Binding ResetCamera}" ToolTip.Tip="Reset Camera">
            <icons:MaterialIcon Kind="Target" />
          </Button>
        </StackPanel>

        <!-- Time of Day Overlay -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8,48,8,8"
                Background="#AA000000" BorderBrush="Transparent" BorderThickness="1"
                CornerRadius="4" Padding="8,4" Width="200">
          <Grid ColumnDefinitions="Auto, *">
            <icons:MaterialIcon Kind="WeatherSunny" Margin="0,0,8,0" Foreground="White" />
            <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding EditorState.TimeOfDay}" 
                    ToolTip.Tip="Time of Day" />
          </Grid>
        </Border>
        
        <!-- Location Overlay -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10" 
                Background="#AA000000" BorderBrush="Transparent" BorderThickness="1"
                CornerRadius="4" Padding="6,4">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="LocationText"
                       Foreground="White"
                       FontFamily="Consolas, Monospace"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Text="0.00N, 0.00E | 0x00000000 (0.0, 0.0, 0.0)" />
            <Button x:Name="CopyLocationButton" 
                    Background="Transparent" BorderThickness="0" Padding="2" Width="24" Height="24"
                    ToolTip.Tip="Copy Location">
              <icons:MaterialIcon Kind="ContentCopy" Width="14" Height="14" Foreground="White" />
            </Button>
          </StackPanel>
        </Border>

        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10, 10, 10, 50" 
                Background="#AA000000" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1"
                CornerRadius="4" Padding="4" Width="208" Height="208">
          <Panel>
            <Image x:Name="MinimapImage" Width="200" Height="200" PointerPressed="OnMinimapPointerPressed" Cursor="Hand" />
            
            <Ellipse x:Name="MinimapPlayerIndicator" Width="8" Height="8" Fill="Red" 
                     HorizontalAlignment="Left" VerticalAlignment="Top" IsHitTestVisible="False" />
          </Panel>
        </Border>
      </Panel>

      <!-- Bottom Splitter -->
      <GridSplitter x:Name="BottomSplitter" Grid.Row="2" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center" 
                    Background="{DynamicResource SemiColorBorder}" 
                    IsVisible="{Binding IsObjectToolActive}" 
                    ResizeDirection="Rows" />

      <!-- Setup Browser Panel -->
      <components:SetupBrowserPanel Grid.Row="3" MinHeight="100"
                                   VerticalAlignment="Stretch"
                                   DataContext="{Binding SetupBrowserPanel}" 
                                   IsVisible="{Binding IsObjectToolActive}" />
    </Grid>

    <!-- GridSplitter for resizable right panel -->
    <GridSplitter x:Name="RightSplitter" Grid.Column="2" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Stretch" 
                  Width="4" 
                  MinWidth="2"
                  Background="Transparent"
                  ResizeDirection="Columns"
                  IsVisible="{Binding !IsReadOnly}" />

    <!-- Right Sidebar: Layers, History & Properties -->
    <Grid x:Name="RightPanels" Grid.Column="3" RowDefinitions="*, Auto, *" IsVisible="{Binding !IsReadOnly}">
      <TabControl Grid.Row="0" Margin="4">
        <TabItem Header="Layers">
          <components:LayersPanel DataContext="{Binding LayersPanel}" />
        </TabItem>
        <TabItem Header="History">
          <components:HistoryPanel DataContext="{Binding HistoryPanel}" />
        </TabItem>
        <TabItem Header="Bookmarks">
          <components:BookmarksPanel DataContext="{Binding BookmarksPanel}" />
        </TabItem>
      </TabControl>
      
      <!-- Horizontal GridSplitter between TabControl and PropertiesPanel -->
      <GridSplitter x:Name="SideBarSplitter" Grid.Row="1" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Center" 
                    Height="4" 
                    MinHeight="2"
                    Background="Transparent"
                    ResizeDirection="Rows" />
      
      <components:PropertiesPanel x:Name="PropertiesPanel" Grid.Row="2" Margin="4" DataContext="{Binding PropertiesPanel}" />
    </Grid>
  </Grid>
</UserControl>

