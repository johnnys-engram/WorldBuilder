{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: WorldBuilder (Debug)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/WorldBuilder.Windows/WorldBuilder.Windows.csproj",
        "-c", "Debug",
        "-p:TreatWarningsAsErrors=false"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
